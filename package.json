{
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite --mode development",
    "build": "vite build && tixyel b -b none",
    "compile": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint widget/src/scripts tests",
    "lint:scss": "stylelint \"widget/src/styles/**/*.scss\"",
    "format": "prettier --write widget/src/scripts tests",
    "format:check": "prettier --check widget/src/scripts tests",
    "fix": "eslint --fix widget/src/scripts tests && prettier --write widget/src/scripts tests"
  },
  "devDependencies": {
    "@tixyel/cli": "3.5.3",
    "@types/node": "25.5.0",
    "eslint": "10.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-sonarjs": "4.0.2",
    "eslint-plugin-unicorn": "64.0.0",
    "jiti": "2.6.1",
    "prettier": "3.8.1",
    "sass": "1.98.0",
    "stylelint": "17.6.0",
    "stylelint-config-recess-order": "7.7.0",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-order": "8.1.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0",
    "vite": "8.0.3",
    "vite-plugin-static-copy": "4.0.0",
    "vitest": "4.1.2"
  },
  "dependencies": {
    "@tixyel/streamelements": "7.3.0",
    "motion": "12.38.0"
  }
}
